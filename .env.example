# Google Sheet that feeds the dashboard. Must be shared as "anyone with the link".
# Defaults to the Engosoft sheet if unset.
SHEET_ID=14kv8Xkv8SeFhF9roekDI0OKmpZBU29YQOlMj03LOKT0

# Optional. Without it the AI assistant still answers the built-in questions
# (best campaign, wasted budget, cheapest CPL, totals, conversion rate, close
# time) from exact figures, but free-form questions are disabled.
OPENAI_API_KEY=

# --- Telegram daily report -------------------------------------------------
# Both must be set for the scheduled report to run. The token is never logged.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cron expression, evaluated in Africa/Cairo. Default: 09:00 daily.
REPORT_CRON=0 9 * * *

# Report language: ar (default) or en.
REPORT_LANG=ar

# Railway sets this automatically; only needed for local production runs.
PORT=3000

# Where the /start subscriber list is stored. On Railway the container
# filesystem resets on every redeploy, so point this at a mounted volume
# (e.g. /data/telegram-subscribers.json) to keep subscribers.
TELEGRAM_SUBSCRIBERS_FILE=./.data/telegram-subscribers.json

# Public URL of this deployment, used for the link at the end of each Telegram
# report. Leave unset and the link is omitted rather than pointing at a 404.
PUBLIC_APP_URL=
